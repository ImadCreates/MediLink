# =============================================================================
# File:        medilink_constraints.sdc
# Project:     MediLink FPGA Emergency Alert Receiver
# Board:       DE10-Lite (MAX 10 FPGA: 10M50DAF484C7G)
# Description: Timing constraints for Intel Quartus Prime TimeQuest Analyzer.
#
# This file declares:
#   1. The primary 50 MHz input clock (MAX10_CLK1_50)
#   2. The 25 MHz derived pixel clock (clk_25mhz, from clk_divider)
#   3. The 1 kHz derived buzzer clock (clk_1khz, from clk_divider)
#   4. False path declarations for I/O and async paths
#
# HOW TO USE IN QUARTUS PRIME LITE:
#   Assignments -> Settings -> TimeQuest Timing Analyzer
#   Add this file under "SDC Files".
#   Or: Place this file in your project directory; Quartus auto-discovers .sdc
#   files that share the project name.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Primary Clock  (50 MHz onboard oscillator -> PIN_P11)
# -----------------------------------------------------------------------------
# Period = 1 / 50,000,000 Hz = 20.000 ns
# The clock is declared on the port MAX10_CLK1_50 (after I/O name mapping).

create_clock -name {MAX10_CLK1_50} \
             -period 20.000 \
             -waveform {0.000 10.000} \
             [get_ports {MAX10_CLK1_50}]


# -----------------------------------------------------------------------------
# 2. Derived: 25 MHz pixel clock (generated by clk_divider toggle register)
# -----------------------------------------------------------------------------
# The 25 MHz clock is generated by a register inside clk_divider.
# We declare it as a generated clock derived from MAX10_CLK1_50.
# Divide-by-2 -> period = 40 ns.
#
# NOTE: The source pin path uses the register output inside the hierarchy.
# Adjust the get_pins path if your hierarchy names differ.

create_generated_clock -name {clk_25mhz} \
    -source [get_ports {MAX10_CLK1_50}] \
    -divide_by 2 \
    [get_pins {u_clk_divider|clk_25mhz}]


# -----------------------------------------------------------------------------
# 3. Derived: 1 kHz buzzer clock (generated by clk_divider counter)
# -----------------------------------------------------------------------------
# The 1 kHz clock is a slow signal for the buzzer. Its extremely long period
# means it does not constrain the design critically, but we declare it to
# avoid unconstrained clock warnings.
#
# Period = 1 / 1,000 Hz = 1,000,000 ns = 1 ms.
# Source is the 50 MHz oscillator; effective division = 50,000.

create_generated_clock -name {clk_1khz} \
    -source [get_ports {MAX10_CLK1_50}] \
    -divide_by 50000 \
    [get_pins {u_clk_divider|clk_1khz}]


# -----------------------------------------------------------------------------
# 4. Input / Output delays (relaxed for switch/LED I/O)
# -----------------------------------------------------------------------------
# Physical switches and LEDs are human-operated and have no strict setup/hold
# requirements relative to the FPGA clock. We set loose delays to prevent
# Quartus from reporting failing I/O paths on these ports.

# Switches (SW[9:0]) -- asynchonous inputs, debounced inside FSM
set_input_delay  -clock {MAX10_CLK1_50} -max 3.0 [get_ports {SW[*]}]
set_input_delay  -clock {MAX10_CLK1_50} -min 0.0 [get_ports {SW[*]}]

# LEDs (LEDR[9:0]) -- registered outputs, loose constraint
set_output_delay -clock {MAX10_CLK1_50} -max 3.0 [get_ports {LEDR[*]}]
set_output_delay -clock {MAX10_CLK1_50} -min 0.0 [get_ports {LEDR[*]}]

# VGA outputs -- driven by 25 MHz pixel clock (generated clock)
set_output_delay -clock {clk_25mhz} -max 2.0 [get_ports {VGA_HS}]
set_output_delay -clock {clk_25mhz} -max 2.0 [get_ports {VGA_VS}]
set_output_delay -clock {clk_25mhz} -max 2.0 [get_ports {VGA_R[*]}]
set_output_delay -clock {clk_25mhz} -max 2.0 [get_ports {VGA_G[*]}]
set_output_delay -clock {clk_25mhz} -max 2.0 [get_ports {VGA_B[*]}]

# GPIO buzzer -- driven from 1 kHz generated clock
set_output_delay -clock {clk_1khz}  -max 2.0 [get_ports {GPIO_0}]


# -----------------------------------------------------------------------------
# 5. False paths for asynchronous clock domain crossings
# -----------------------------------------------------------------------------
# The fsm_state register is clocked by MAX10_CLK1_50 (50 MHz) but is read by
# vga_display_gen which is clocked by clk_25mhz (25 MHz).
# This is a CDC crossing. The paths are quasi-static (state changes only on
# human switch events, not every cycle), so we declare them false paths to
# suppress timing analysis warnings.
# 
# NOTE: For a production design, proper CDC synchronizers should be added.
# For this prototype, the signals are stable long before they are sampled.

set_false_path -from [get_clocks {MAX10_CLK1_50}] -to [get_clocks {clk_25mhz}]
set_false_path -from [get_clocks {clk_25mhz}]     -to [get_clocks {MAX10_CLK1_50}]


# -----------------------------------------------------------------------------
# 6. Derive PLL clocks (if Quartus PLL IP is added in a future sprint)
# -----------------------------------------------------------------------------
# If you later replace clk_divider with a proper PLL (ALTPLL IP core),
# uncomment and use:
#   derive_pll_clocks
#   derive_clock_uncertainty
#
# For now these are commented out as we use manual clock division.

# derive_pll_clocks
# derive_clock_uncertainty

# =============================================================================
# End of medilink_constraints.sdc
# =============================================================================
